# Short-form Video Generation Harness — 환경 변수 예시
# 이 파일을 복사해 .env 로 이름을 바꾼 뒤 실제 키 값을 채워 넣으세요.
#   cp .env.example .env
# .env 파일은 절대 커밋하지 마세요 (.gitignore 에 이미 포함됨).

# ─────────────────────────────────────────────────────────
# GOOGLE_API_KEY
#   발급처 : https://aistudio.google.com
#   용도   : Gemini(레퍼런스 분석·훅 생성·QA 판정),
#            Nano Banana / Gemini 이미지 생성(장면 이미지, generate_content 기반),
#            Veo(히어로 클립 image-to-video),
#            Google TTS(보이스오버, 옵션)
#   주의   : 이 키 하나로 위 네 가지 모델을 모두 호출합니다.
#            채점자가 자신의 키를 주입해 실행하므로 키를 공유하지 마세요.
# ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# IMAGEN_MODEL: 장면 이미지 생성 모델. 기본값 gemini-2.5-flash-image(Nano Banana).
#   Imagen 전용 API(generate_images)가 아니라 Gemini generate_content의 이미지
#   응답 모달리티를 사용하며, Imagen과 별도 quota다. Imagen은 2026-08-17 지원
#   종료가 예고되어 기본값에서 제외했다. 필요 시 imagen-4.0-generate-001 등으로
#   되돌릴 수 있다.
# IMAGEN_MODEL=gemini-2.5-flash-image
